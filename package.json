{
  "name": "mobile-mechanic-software",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e:bootstrap": "node tooling/scripts/run-e2e-bootstrap.mjs",
    "test:e2e:prepare-env": "node tooling/scripts/prepare-e2e-env.mjs",
    "test:e2e:prepare": "node tooling/scripts/with-e2e-bootstrap-lock.mjs test:e2e:prepare:unlocked",
    "test:e2e:prepare:unlocked": "node tooling/scripts/run-e2e-prepare.mjs",
    "test:e2e:mobile": "pnpm --filter @mobile-mechanic/e2e test:mobile",
    "test:e2e:mobile:ci": "node tooling/scripts/run-e2e-ci.mjs mobile",
    "test:e2e": "pnpm --filter @mobile-mechanic/e2e test",
    "test:e2e:headed": "pnpm --filter @mobile-mechanic/e2e test:headed",
    "test:e2e:install": "pnpm --filter @mobile-mechanic/e2e install:browsers",
    "test:e2e:verify-seed": "node tooling/scripts/assert-e2e-seed-integrity.mjs",
    "test:e2e:web": "pnpm --filter @mobile-mechanic/e2e test:web",
    "test:e2e:web:ci": "node tooling/scripts/run-e2e-ci.mjs web",
    "test:e2e:ci": "node tooling/scripts/run-e2e-ci.mjs full",
    "bootstrap:dev-users": "node tooling/scripts/bootstrap-dev-users.mjs",
    "bootstrap:demo-data": "node tooling/scripts/bootstrap-demo-data.mjs",
    "bootstrap:dispatch-stress": "node tooling/scripts/bootstrap-dispatch-stress.mjs",
    "db:start": "pnpm exec supabase start",
    "db:stop": "pnpm exec supabase stop",
    "db:reset": "node tooling/scripts/with-e2e-bootstrap-lock.mjs db:reset:unlocked",
    "db:reset:unlocked": "node tooling/scripts/reset-local-db.mjs",
    "db:types": "pnpm exec supabase gen types typescript --local > packages/types/src/database.generated.ts"
  },
  "devDependencies": {
    "supabase": "2.84.4",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.3",
    "tsup": "^8.5.1",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.0",
      "react-dom": "19.2.0"
    }
  }
}
