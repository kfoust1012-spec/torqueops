# Copy these values into apps/web/.env.local and apps/mobile/.env.local.
# The local anon key is printed by `pnpm db:start` when Supabase boots.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Web server-only payments variables. Copy these into apps/web/.env.local.
# Use the canonical public web origin for this environment. Do not include a trailing slash.
# Examples:
# APP_URL=https://staging.example.com
# APP_URL=https://app.example.com
APP_URL=http://localhost:3000
SUPABASE_SERVICE_ROLE_KEY=PLACEHOLDER_SUPABASE_SERVICE_ROLE_KEY
# Must be unique per environment so staging links never validate in production.
CUSTOMER_DOCUMENT_TOKEN_SECRET=PLACEHOLDER_CUSTOMER_DOCUMENT_TOKEN_SECRET
# Required if procurement provider credentials (for example, PartsTech) will be stored server-side.
PROCUREMENT_PROVIDER_CREDENTIAL_SECRET=PLACEHOLDER_PROCUREMENT_PROVIDER_CREDENTIAL_SECRET
# Required if migration-source credentials (for example, Shopmonkey) will be stored server-side.
MIGRATION_SOURCE_CREDENTIAL_SECRET=PLACEHOLDER_MIGRATION_SOURCE_CREDENTIAL_SECRET
# Required if company-level SMS provider credentials will be stored server-side.
SMS_PROVIDER_CREDENTIAL_SECRET=PLACEHOLDER_SMS_PROVIDER_CREDENTIAL_SECRET
# Leave Carfax blank until a real provider endpoint and key are assigned.
CARFAX_API_KEY=
CARFAX_API_BASE_URL=
STRIPE_SECRET_KEY=PLACEHOLDER_STRIPE_SECRET_KEY
# Use a Stripe key that matches this environment. Staging should use a test key; production should use a live key.
# Use the Stripe webhook signing secret for this exact environment and mode.
STRIPE_WEBHOOK_SECRET=PLACEHOLDER_STRIPE_WEBHOOK_SECRET
# Required for real launch if you expect queued communications and retries to process reliably.
COMMUNICATIONS_PROCESS_SECRET=
# Required for real launch if you expect queued or webhook-triggered Shopmonkey imports to process outside the settings UI.
IMPORTS_PROCESS_SECRET=
# Optional for Vercel Cron. When set, Vercel sends it as the Authorization bearer token to cron routes.
CRON_SECRET=
# Required for real launch when email delivery is enabled.
COMMUNICATIONS_FROM_EMAIL=
COMMUNICATIONS_REPLY_TO_EMAIL=
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
# Required for real launch when SMS delivery is enabled.
COMMUNICATIONS_FROM_PHONE=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
